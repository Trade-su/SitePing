{
  "name": "@siteping/adapter-localstorage",
  "version": "0.4.2",
  "description": "localStorage adapter for Siteping — client-side feedback persistence without a server",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node ../../scripts/fix-dts.mjs dist",
    "check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "siteping",
    "localstorage",
    "adapter",
    "feedback",
    "client-side",
    "no-server",
    "demo",
    "typescript"
  ],
  "author": "neosianexus",
  "license": "MIT",
  "homepage": "https://siteping.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NeosiaNexus/SitePing.git",
    "directory": "packages/adapter-localstorage"
  },
  "bugs": {
    "url": "https://github.com/NeosiaNexus/SitePing/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@siteping/core": "workspace:*"
  }
}
